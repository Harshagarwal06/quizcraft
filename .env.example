# Database
# Local dev: a SQLite file. Production (Turso): a libsql:// URL + auth token.
DATABASE_URL="file:./dev.db"
# DATABASE_URL="libsql://your-db.turso.io"
# DATABASE_AUTH_TOKEN="..."   # only needed for Turso (remote libsql)

# Authentication - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Local: http://localhost:3001  |  Production: your deployed URL (e.g. https://quizcraft.vercel.app)
NEXTAUTH_URL="http://localhost:3001"
AUTH_URL="http://localhost:3001"
AUTH_TRUST_HOST="true"

# LLM Provider — which model generates the quiz (hf | anthropic | gemini)
LLM_PROVIDER="hf"

# HuggingFace — Qwen2.5-72B-Instruct (set LLM_PROVIDER=hf)
HF_API_KEY="hf_..."

# Anthropic — Claude Opus 4.8 (set LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY="sk-ant-..."

# Google Gemini — used for the optional topic-expansion stage AND, when
# LLM_PROVIDER=gemini, as the quiz generator itself (so the whole app can run
# on this one key). Topic expansion is skipped if GEMINI_API_KEY is unset.
GEMINI_API_KEY="..."
# GEMINI_MODEL="gemini-2.5-flash"   # free-tier default (generation + expansion)
