# Database
# Local dev: a SQLite file. Production (Turso): a libsql:// URL + auth token.
DATABASE_URL="file:./dev.db"
# DATABASE_URL="libsql://your-db.turso.io"
# DATABASE_AUTH_TOKEN="..."   # only needed for Turso (remote libsql)

# Authentication - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Local: http://localhost:3001  |  Production: your deployed URL (e.g. https://quizcraft.vercel.app)
NEXTAUTH_URL="http://localhost:3001"
AUTH_URL="http://localhost:3001"
AUTH_TRUST_HOST="true"

# LLM Provider — which model generates the quiz (hf | gemini)
LLM_PROVIDER="hf"

# Evidence-first generation. Disable only while rolling back to the legacy
# full-text generator for new quizzes; existing quizzes always remain playable.
EVIDENCE_PIPELINE_ENABLED="true"

# Prompt-only quizzes use Gemini Google Search grounding. This requires
# GEMINI_API_KEY and at least two acceptable source domains, including one
# authoritative source.
WEB_GROUNDING_ENABLED="true"
# Comma-separated deployment-specific authority allowlist additions.
# TRUSTED_SOURCE_DOMAINS="example.edu,docs.example.com"

# Source-grounded Study Coach. The coach may propose one bounded lesson, quiz,
# mastery review, source request, or rest action, but never executes generation
# or plan changes until the learner confirms.
COACH_AGENT_ENABLED="true"
# Shadow mode records planner decisions without surfacing a new proposal.
COACH_AGENT_SHADOW="false"

# Verifier provider — the INDEPENDENT model that audits generated questions
# (the Quality Engine). Optional: defaults to the provider opposite LLM_PROVIDER
# for cross-model verification (e.g. generate hf → verify gemini). Set to
# "hf" | "gemini" to override. Falls back to same-model self-check if the
# cross provider's key is missing.
# VERIFIER_PROVIDER="gemini"

# Eval judge — the INDEPENDENT judge used by the Phase 2 eval harness
# (`npm run eval:live`) to score the benchmark and calibrate against human labels.
# Optional: defaults to the provider opposite LLM_PROVIDER (independent of the
# generator). Set it to the provider the repair loop does NOT use to also make the
# post-repair number independent of repair. Not used by the running app.
# EVAL_JUDGE_PROVIDER="gemini"

# HuggingFace — Qwen2.5-72B-Instruct (set LLM_PROVIDER=hf)
HF_API_KEY="hf_..."

# Google Gemini — used for search-grounded prompt research and, when
# LLM_PROVIDER=gemini, structured generation. Prompt-only evidence quizzes
# require this key; PDF and notes quizzes remain provider-agnostic.
GEMINI_API_KEY="..."
# GEMINI_MODEL="gemini-2.5-flash"   # free-tier default (generation + expansion)
