generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// NextAuth required tables
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  quizzes  Quiz[]
  attempts Attempt[]
  conceptReviews ConceptReview[]
  sourceDocuments SourceDocument[]
  studyPlans StudyPlan[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App models
model Quiz {
  id            String   @id @default(cuid())
  userId        String
  title         String
  sourceType    String   // "pdf" | "notes" | "prompt"
  sourceSummary String?
  questionCount Int
  createdAt     DateTime @default(now())
  purpose       String   @default("standard") // "standard" | "review"
  sourceQuizId  String?  // original standard quiz for targeted review sessions
  sourceDocumentId String?
  generationStatus String @default("legacy") // legacy | preparing | first_batch_ready | complete | partial | failed
  targetQuestionCount Int?
  firstBatchReadyAt DateTime?
  generationError String?

  // Quality-engine (verification) fields
  groundingText       String? // the material the generator saw (post-expansion), for the verifier
  verificationStatus  String  @default("pending") // pending | verifying | verified | skipped | failed
  verifiedAt          DateTime?
  verifierModel       String? // e.g. "gemini-2.5-flash" — which model audited
  verificationSummary String? // JSON: { total, passedInitial, failedInitial, repaired, flagged }

  // Provenance — attribute quality to a specific model + prompt version
  generatorModel      String? // model that generated the quiz
  generatorPromptHash String? // short sha256 of SYSTEM_PROMPT at generation time
  verifierPromptHash  String? // short sha256 of VERIFIER_SYSTEM_PROMPT at verify time

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceDocument SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  questions Question[]
  attempts  Attempt[]
  conceptReviews ConceptReview[]
  blueprintItems QuizBlueprintItem[]
  generationBatches QuizGenerationBatch[]
  generationTraces GenerationTrace[]

  @@index([userId, createdAt(sort: Desc)])
}

model Question {
  id            String  @id @default(cuid())
  quizId        String
  stem          String
  options       String  // JSON: [{id, text}]
  correctOption String  // "A" | "B" | "C" | "D"
  explanation   String
  difficulty    String  // "easy" | "medium" | "hard"
  topic         String
  order         Int
  reviewConceptKey String?
  blueprintItemId String? @unique
  optionExplanations String?
  evidenceStatus String @default("missing") // valid | missing | invalid

  // Quality-engine (verification) fields
  verdict            String? // null (unverified) | "pass" | "repaired" | "flagged"
  verificationDetail String? // JSON: { grounded, answerSupported, uniqueAnswer, distractorsValid, reasons[], initialVerdict, suggestedCorrectOptionId? }

  quiz          Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  blueprintItem QuizBlueprintItem? @relation(fields: [blueprintItemId], references: [id], onDelete: SetNull)
  answerRecords AnswerRecord[]
  evidence QuestionEvidence[]
}

model SourceDocument {
  id                 String   @id @default(cuid())
  userId             String
  kind               String   // pdf | notes | web
  title              String
  fullText           String
  contentHash        String
  originUrl          String?
  extractionMetadata String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks     SourceChunk[]
  references SourceReference[]
  quizzes    Quiz[]
  studyPlanLinks StudyPlanSource[]

  @@unique([userId, contentHash])
}

model SourceChunk {
  id               String @id @default(cuid())
  sourceDocumentId String
  ordinal          Int
  pageStart        Int?
  pageEnd          Int?
  section          String?
  text             String
  normalizedText   String
  tokenCount       Int

  sourceDocument SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  references     ChunkReference[]
  evidence       QuestionEvidence[]
  lessonEvidence CoachLessonEvidence[]

  @@unique([sourceDocumentId, ordinal])
  @@index([sourceDocumentId])
}

model SourceReference {
  id               String @id @default(cuid())
  sourceDocumentId String
  title            String
  url              String
  domain           String
  authority        String // authoritative | established | rejected

  sourceDocument SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  chunks         ChunkReference[]

  @@unique([sourceDocumentId, url])
}

model ChunkReference {
  sourceChunkId    String
  sourceReferenceId String

  sourceChunk    SourceChunk    @relation(fields: [sourceChunkId], references: [id], onDelete: Cascade)
  sourceReference SourceReference @relation(fields: [sourceReferenceId], references: [id], onDelete: Cascade)

  @@id([sourceChunkId, sourceReferenceId])
}

model QuizBlueprintItem {
  id             String @id @default(cuid())
  quizId         String
  slot           Int
  conceptKey     String
  topic          String
  objective      String
  difficulty     String
  skillType      String
  retrievalQuery String
  requiredFacts  String
  seedChunkIds   String
  status         String @default("pending") // pending | generating | ready | failed
  failureCode    String?
  batchIndex     Int

  quiz     Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question Question?

  @@unique([quizId, slot])
  @@index([quizId, batchIndex])
}

model QuizGenerationBatch {
  id           String   @id @default(cuid())
  quizId       String
  batchIndex   Int
  status       String   @default("pending") // pending | generating | verifying | ready | failed
  attemptCount Int      @default(0)
  errorCode    String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, batchIndex])
  @@index([quizId, status])
}

model QuestionEvidence {
  id            String @id @default(cuid())
  questionId    String
  sourceChunkId String
  quote         String
  displayOrder  Int

  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  sourceChunk SourceChunk @relation(fields: [sourceChunkId], references: [id], onDelete: Cascade)

  @@unique([questionId, displayOrder])
}

model GenerationTrace {
  id            String   @id @default(cuid())
  quizId        String?
  stage         String
  batchIndex    Int?
  provider      String?
  model         String?
  durationMs    Int
  inputTokens   Int?
  outputTokens  Int?
  cacheTokens   Int?
  questionCount Int?
  retryCount    Int      @default(0)
  status        String
  errorCode     String?
  createdAt     DateTime @default(now())

  quiz Quiz? @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, stage])
  @@index([stage, createdAt])
}

model ConceptReview {
  id                 String    @id @default(cuid())
  userId             String
  sourceQuizId       String
  conceptKey         String
  label              String
  stage              Int       @default(0)
  consecutiveCorrect Int       @default(0)
  dueAt              DateTime?
  lastReviewedAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceQuiz Quiz @relation(fields: [sourceQuizId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceQuizId, conceptKey])
  @@index([userId, dueAt])
}

model Attempt {
  id             String    @id @default(cuid())
  quizId         String
  userId         String
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  score          Int?
  totalQuestions Int

  quiz          Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  answerRecords AnswerRecord[]

  @@index([userId, completedAt])
}

model AnswerRecord {
  id               String  @id @default(cuid())
  attemptId        String
  questionId       String
  selectedOption   String
  isCorrect        Boolean
  timeMs           Int?

  attempt  Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
}

model StudyPlan {
  id            String   @id @default(cuid())
  userId        String
  examTitle     String
  examDate      DateTime
  targetScore   Int
  dailyMinutes  Int
  availableDays String
  status        String   @default("active") // active | archived
  activeKey     String?  @unique
  stateVersion  Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources  StudyPlanSource[]
  concepts PlanConcept[]
  threads  CoachThread[]
  actions  CoachAction[]
  lessons  CoachLesson[]
  runs     CoachRun[]

  @@index([userId, status])
}

model StudyPlanSource {
  studyPlanId     String
  sourceDocumentId String
  createdAt       DateTime @default(now())

  studyPlan     StudyPlan     @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  sourceDocument SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)

  @@id([studyPlanId, sourceDocumentId])
  @@index([sourceDocumentId])
}

model PlanConcept {
  id               String   @id @default(cuid())
  studyPlanId      String
  sourceDocumentId String
  sourceQuizId     String?
  conceptKey       String
  label            String
  importance       Float    @default(0.5)
  objectives       String
  seedChunkIds     String
  proficiency      Float    @default(0)
  lastActivityAt   DateTime?
  lastLessonAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  studyPlan StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)

  @@unique([studyPlanId, conceptKey])
  @@index([studyPlanId, sourceDocumentId])
}

model CoachThread {
  id          String   @id @default(cuid())
  studyPlanId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studyPlan StudyPlan     @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  messages  CoachMessage[]

  @@unique([studyPlanId])
}

model CoachMessage {
  id                String   @id @default(cuid())
  threadId          String
  role              String // user | assistant
  content           String
  citations         String?
  pendingPlanUpdate String?
  proposedActionId  String?
  createdAt         DateTime @default(now())

  thread CoachThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model CoachAction {
  id                String   @id @default(cuid())
  studyPlanId       String
  type              String // lesson | quiz | review | request_source | rest
  status            String   @default("proposed")
  title             String
  rationale         String
  estimatedMinutes  Int
  conceptKeys       String
  sourceDocumentIds String
  payload           String?
  planStateVersion  Int
  generatedQuizId   String?
  readyHref         String?
  errorCode         String?
  errorMessage      String?
  approvedAt        DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  studyPlan StudyPlan    @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  lesson    CoachLesson?

  @@index([studyPlanId, status, createdAt])
}

model CoachLesson {
  id             String   @id @default(cuid())
  studyPlanId    String
  actionId       String   @unique
  title          String
  conceptKey     String
  sections       String
  misconception  String
  workedExample  String?
  summary        String
  createdAt      DateTime @default(now())
  completedAt    DateTime?

  studyPlan StudyPlan             @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)
  action    CoachAction            @relation(fields: [actionId], references: [id], onDelete: Cascade)
  evidence  CoachLessonEvidence[]

  @@index([studyPlanId, createdAt])
}

model CoachLessonEvidence {
  id            String @id @default(cuid())
  lessonId      String
  sourceChunkId String
  quote         String
  displayOrder  Int

  lesson      CoachLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  sourceChunk SourceChunk @relation(fields: [sourceChunkId], references: [id], onDelete: Cascade)

  @@unique([lessonId, displayOrder])
}

model CoachRun {
  id                 String   @id @default(cuid())
  studyPlanId        String
  trigger            String
  candidateActions   String
  selectedActionType String?
  selectedActionId   String?
  provider           String?
  model              String?
  durationMs         Int
  inputTokens        Int?
  outputTokens       Int?
  status             String
  policyRejected     Boolean  @default(false)
  errorCode          String?
  createdAt          DateTime @default(now())

  studyPlan StudyPlan @relation(fields: [studyPlanId], references: [id], onDelete: Cascade)

  @@index([studyPlanId, createdAt])
}
